{application,raffley,
             [{modules,['Elixir.Raffley','Elixir.Raffley.Admin',
                        'Elixir.Raffley.Application',
                        'Elixir.Raffley.Charities',
                        'Elixir.Raffley.Charities.Charity',
                        'Elixir.Raffley.Mailer','Elixir.Raffley.Raffles',
                        'Elixir.Raffley.Raffles.Raffle','Elixir.Raffley.Repo',
                        'Elixir.Raffley.Rules','Elixir.RaffleyWeb',
                        'Elixir.RaffleyWeb.AdminRaffleLive.Form',
                        'Elixir.RaffleyWeb.AdminRaffleLive.Index',
                        'Elixir.RaffleyWeb.CharityLive.FormComponent',
                        'Elixir.RaffleyWeb.CharityLive.Index',
                        'Elixir.RaffleyWeb.CharityLive.Show',
                        'Elixir.RaffleyWeb.Components.BadgeComponents',
                        'Elixir.RaffleyWeb.Components.BannerComponents',
                        'Elixir.RaffleyWeb.CoreComponents',
                        'Elixir.RaffleyWeb.Endpoint',
                        'Elixir.RaffleyWeb.ErrorHTML',
                        'Elixir.RaffleyWeb.ErrorJSON',
                        'Elixir.RaffleyWeb.EstimatorLive',
                        'Elixir.RaffleyWeb.Gettext',
                        'Elixir.RaffleyWeb.Layouts',
                        'Elixir.RaffleyWeb.PageController',
                        'Elixir.RaffleyWeb.PageHTML',
                        'Elixir.RaffleyWeb.RaffleLive.Index',
                        'Elixir.RaffleyWeb.RaffleLive.Show',
                        'Elixir.RaffleyWeb.Router',
                        'Elixir.RaffleyWeb.RuleController',
                        'Elixir.RaffleyWeb.RuleHTML',
                        'Elixir.RaffleyWeb.Telemetry']},
              {compile_env,[{raffley,['Elixir.RaffleyWeb.Gettext'],error},
                            {raffley,[dev_routes],{ok,true}}]},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,runtime_tools,
                             phoenix,phoenix_ecto,ecto_sql,myxql,phoenix_html,
                             phoenix_live_reload,phoenix_live_view,
                             phoenix_live_dashboard,esbuild,tailwind,swoosh,
                             finch,telemetry_metrics,telemetry_poller,gettext,
                             jason,dns_cluster,bandit]},
              {description,"raffley"},
              {registered,[]},
              {vsn,"0.1.0"},
              {mod,{'Elixir.Raffley.Application',[]}}]}.
